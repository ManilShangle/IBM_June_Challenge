# Which backend to use for Granite inference: replicate | watsonx | huggingface | ollama
GRANITE_BACKEND=replicate

# --- Replicate (primary - lowest friction, GitHub login only) ---
# 1. Sign up at replicate.com with GitHub
# 2. Claim free credit: https://replicate.fyi/ibm
# 3. Create a token at replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_MODEL=ibm-granite/granite-3.3-8b-instruct

# --- watsonx.ai (alternative, official IBM path) ---
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# --- Hugging Face Inference API (fallback) ---
HF_API_TOKEN=
HF_MODEL_ID=ibm-granite/granite-3.1-8b-instruct

# --- Ollama (local fallback) ---
OLLAMA_MODEL=granite3.1-dense:8b
OLLAMA_HOST=http://localhost:11434
